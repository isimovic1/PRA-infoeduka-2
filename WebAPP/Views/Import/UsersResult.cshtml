@model WebApp.ViewModels.Import.ImportResultVM
@{
    ViewData["Title"] = "Import result";
}

<section class="container py-4" style="max-width: 960px;">
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-white">
            <h1 class="h4 mb-0">Import result</h1>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-2">
                <div class="col-sm-6 col-lg-3">
                    <div class="p-3 bg-light rounded-3 text-center">
                        <div class="small text-muted">Batch ID</div>
                        <div class="h5 mb-0">@Model.BatchId</div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="p-3 bg-light rounded-3 text-center">
                        <div class="small text-muted">Total rows</div>
                        <div class="h5 mb-0">@Model.TotalRows</div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="p-3 bg-success text-white rounded-3 text-center">
                        <div class="small">Success</div>
                        <div class="h5 mb-0">@Model.SuccessCount</div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="p-3 bg-danger text-white rounded-3 text-center">
                        <div class="small">Errors</div>
                        <div class="h5 mb-0">@Model.ErrorCount</div>
                    </div>
                </div>
            </div>

            @if (Model.Errors?.Any() ?? false)
            {
                <hr />
                <h5 class="mb-3">Errors</h5>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 100px;">Row</th>
                                <th>Error</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model.Errors)
                            {
                                <tr>
                                    <td>@e.RowNumber</td>
                                    <td class="text-danger">@e.Error</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <a class="btn btn-outline-primary" asp-action="Users">Import another file</a>
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Back to Home</a>
                <a class="btn btn-outline-dark ms-auto" asp-action="Batch" asp-route-id="@Model.BatchId" target="_blank">View raw batch JSON</a>
            </div>
        </div>
    </div>
</section>
