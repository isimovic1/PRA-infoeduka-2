@model IEnumerable<WebApp.ViewModels.Courses.CourseVM>
@{
    ViewData["Title"] = "Courses";
}

<h2>Courses</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input class="form-control" type="text" name="q" placeholder="Search..." value="@(Context.Request.Query["q"])" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<table class="table table-hover align-middle">
    <thead>
        <tr><th>Name</th><th>Description</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.ShortDescription</td>
                <td>
                    <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@c.Id">Open</a>
                </td>
            </tr>
        }
    </tbody>
</table>
