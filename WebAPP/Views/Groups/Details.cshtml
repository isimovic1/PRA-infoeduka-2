@model WebApp.ViewModels.Groups.ManageGroupVM
@{
    ViewData["Title"] = "Group";
}

<h2>@Model.Group.Name</h2>

@if (TempData["Msg"] is string ok)
{
     <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err)
{
     <div class="alert alert-danger">@err</div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header">Members</div>
            <div class="card-body p-0">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th style="width:38px;"></th>
                            <th>Name</th>
                            <th>Email</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th style="width:280px;"></th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Members.Count == 0)
                        {
                            <tr><td colspan="4" class="text-muted ps-3">No students in this group yet.</td></tr>
                        }
                        else
                        {
                            @foreach (var m in Model.Members)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">S</span></td>
                                    <td>@m.FirstName @m.LastName</td>
                                    <td>@m.Email</td>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <td class="text-end">
                                            <div class="d-inline-flex">
                                                <form asp-action="RemoveMember" method="post" class="me-2"
                                                      onsubmit="return confirm('Remove this student from the group?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@Model.Group.Id" />
                                                    <input type="hidden" name="userId" value="@m.Id" />
                                                    <button class="btn btn-sm btn-outline-danger">Remove</button>
                                                </form>

                                                <form asp-action="MoveMember" method="post" class="d-inline-flex">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@Model.Group.Id" />
                                                    <input type="hidden" name="userId" value="@m.Id" />
                                                    <select name="newGroupId" class="form-select form-select-sm me-2" style="width:180px">
                                                        @foreach (var g in Model.OtherGroups)
                                                        {
                                                            <option value="@g.Id">@g.Name</option>
                                                        }
                                                    </select>
                                                    <button class="btn btn-sm btn-outline-secondary">Move</button>
                                                </form>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-link">Back to groups</a>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">Add student to this group</div>
                <div class="card-body">
                    <form method="get" class="d-flex mb-3">
                        <input type="hidden" name="id" value="@Model.Group.Id" />
                        <input name="q" value="@Model.Q" class="form-control me-2" placeholder="Search students (name/email)..." />
                        <button class="btn btn-primary">Search</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.Q))
                    {
                        if (Model.SearchResults.Count == 0)
                        {
                            <div class="text-muted">No students found.</div>
                        }
                        else
                        {
                            <ul class="list-group">
                                @foreach (var s in Model.SearchResults)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-semibold">@s.FirstName @s.LastName</div>
                                            <div class="text-muted small">@s.Email</div>
                                        </div>
                                        <form asp-action="AddMember" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.Group.Id" />
                                            <input type="hidden" name="userId" value="@s.Id" />
                                            <button class="btn btn-sm btn-success">Add</button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        }
                    }
                    <div class="form-text mt-2">
                        Tip: to <b>move</b> a student, use the Move button in the table.
                        @* If your API forbids removing students from groups, removal will show an error. *@
                    </div>
                </div>
            </div>
        </div>
    }
</div>
