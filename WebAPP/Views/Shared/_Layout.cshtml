<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - INFOEDUKA2</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebAPP.styles.css" asp-append-version="true" />
</head>
<body>
    @if (TempData["Msg"] is string ok)
    {
        <div class="alert alert-success container mt-2">@ok</div>
    }
    @if (TempData["Err"] is string err)
    {
        <div class="alert alert-danger container mt-2">@err</div>
    }
    <header>
        <nav class="navbar navbar-expand-md navbar-dark navbar-glass sticky-top shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="brand-logo me-2">IE</span>
                    <span class="brand-text">Infoeduka<span class="brand-2">2</span></span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="mainNav" class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                        </li>
                       
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Groups" asp-action="Index">Groups</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Import" asp-action="Users">Import users</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item me-2 d-none d-md-block">
                                <span class="nav-welcome text-white-50">
                                    Hello, @User.FindFirst("FullName")?.Value
                                </span>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminUsers" asp-action="Index">Users</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminCourses" asp-action="Index">Courses (Admin)</a>
                                </li>
                            }


                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Notifications" asp-action="Index">
                                    Notifications <span id="notifBadge" class="badge rounded-pill bg-danger ms-1" style="display:none"></span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">Profile</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="ms-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light text-primary fw-semibold">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item ms-1">
                                <a class="btn btn-sm btn-light text-primary fw-semibold" asp-controller="Auth" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - INFOEDUKA2 -
            <a asp-controller="Home" asp-action="Index">Home</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            // Active link
            const path = location.pathname.toLowerCase();
            document.querySelectorAll('.navbar .nav-link').forEach(a => {
                const href = a.getAttribute('href');
                if (!href) return;
                const clean = href.toLowerCase();
                if (clean === '/' ? path === '/' : path.startsWith(clean)) {
                    a.classList.add('active');
                }
            });

            // Shrink on scroll
            const nav = document.querySelector('.navbar');
            const onScroll = () => nav.classList.toggle('navbar-scrolled', window.scrollY > 10);
            onScroll(); window.addEventListener('scroll', onScroll);
        })();
    </script>

</body>
</html>
