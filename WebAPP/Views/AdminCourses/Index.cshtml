@model IEnumerable<WebApp.ViewModels.Courses.CourseVM>
@{
    ViewData["Title"] = "Courses (Admin)";
    var q = (string?)ViewBag.Q ?? "";
}
<h2>Courses (Admin)</h2>

@if (TempData["Msg"] is string ok)
{
     <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err)
{
     <div class="alert alert-danger">@err</div>
}

<form method="get" class="row gy-2 gx-2 align-items-end mb-3">
    <div class="col-md-6">
        <label class="form-label">Search</label>
        <input class="form-control" type="text" name="q" value="@q" placeholder="Course name or description" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100">Search</button>
    </div>
    <div class="col-md-4 text-md-end">
        <a class="btn btn-success" asp-action="Create">New course</a>
    </div>
</form>

<table class="table table-hover align-middle">
    <thead>
        <tr><th>#</th><th>Name</th><th>Description</th><th class="text-end"></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.Name</td>
                <td>@c.ShortDescription</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-primary" asp-action="Manage" asp-route-id="@c.Id">Manage</a>
                    <form asp-action="Delete" method="post" class="d-inline"
                          onsubmit="return confirm('Delete this course? This cannot be undone.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@c.Id" />
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
